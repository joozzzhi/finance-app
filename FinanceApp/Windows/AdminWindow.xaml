<Window x:Class="FinanceApp.Windows.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#FF5722">
            <Grid Margin="20,0">
                <TextBlock Text="Панель администратора"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="AdminNameText"
                               FontSize="14" Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"/>
                    <Button Content="Выход"
                            Background="#E64A19" Foreground="White"
                            BorderThickness="0" Padding="15,5"
                            FontSize="13" Cursor="Hand"
                            Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Содержимое -->
        <TabControl Grid.Row="1" Margin="15" FontSize="14">

            <!-- Управление пользователями -->
            <TabItem Header="  Пользователи  ">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Управление пользователями"
                               FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,15" Foreground="#333"/>

                    <DataGrid x:Name="UsersGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              GridLinesVisibility="Horizontal"
                              CanUserAddRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding UserID}" Width="50"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="*"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding RoleDisplay}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Удалить пользователя"
                                Background="#F44336" Foreground="White"
                                BorderThickness="0" Padding="20,8"
                                FontSize="13" Cursor="Hand"
                                Click="DeleteUser_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Статистика -->
            <TabItem Header="  Статистика  ">
                <Grid Margin="20">
                    <StackPanel>
                        <TextBlock Text="Общая статистика системы"
                                   FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,20" Foreground="#333"/>

                        <UniformGrid Columns="2" Margin="0,0,0,20">
                            <Border Background="White" CornerRadius="8" Margin="5" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Всего пользователей" FontSize="13" Foreground="#888"/>
                                    <TextBlock x:Name="TotalUsersText"
                                               Text="0" FontSize="32"
                                               FontWeight="Bold" Foreground="#FF5722"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="8" Margin="5" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Всего транзакций" FontSize="13" Foreground="#888"/>
                                    <TextBlock x:Name="TotalTransactionsText"
                                               Text="0" FontSize="32"
                                               FontWeight="Bold" Foreground="#2196F3"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="8" Margin="5" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Общий доход (все)" FontSize="13" Foreground="#888"/>
                                    <TextBlock x:Name="AllIncomesText"
                                               Text="0 ₽" FontSize="24"
                                               FontWeight="Bold" Foreground="#4CAF50"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="8" Margin="5" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Общий расход (все)" FontSize="13" Foreground="#888"/>
                                    <TextBlock x:Name="AllExpensesText"
                                               Text="0 ₽" FontSize="24"
                                               FontWeight="Bold" Foreground="#F44336"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
