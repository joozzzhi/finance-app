<Window x:Class="FinanceApp.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="450" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid>
        <Border Background="White" CornerRadius="10" Margin="30"
                Padding="30" BorderBrush="#E0E0E0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Регистрация"
                           FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"
                           Foreground="#333333"/>

                <TextBlock Text="Логин" FontSize="13" Margin="0,0,0,5" Foreground="#666666"/>
                <TextBox x:Name="UsernameTextBox"
                         Height="35" FontSize="14"
                         Padding="8,5"
                         BorderBrush="#CCCCCC"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Пароль" FontSize="13" Margin="0,0,0,5" Foreground="#666666"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="35" FontSize="14"
                             Padding="8,5"
                             BorderBrush="#CCCCCC"
                             Margin="0,0,0,15"/>

                <TextBlock Text="Подтверждение пароля" FontSize="13" Margin="0,0,0,5" Foreground="#666666"/>
                <PasswordBox x:Name="ConfirmPasswordBox"
                             Height="35" FontSize="14"
                             Padding="8,5"
                             BorderBrush="#CCCCCC"
                             Margin="0,0,0,20"/>

                <Button Content="Зарегистрироваться"
                        Height="38" FontSize="14"
                        Background="#4CAF50" Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="RegisterButton_Click"
                        Margin="0,0,0,10"/>

                <Button Content="Назад"
                        Height="35" FontSize="13"
                        Background="Transparent"
                        Foreground="#999999"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="BackButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
