<Window x:Class="FinanceApp.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ваши финансы" Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#4CAF50">
            <Grid Margin="20,0">
                <TextBlock Text="Ваши финансы"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="UserNameText"
                               FontSize="14" Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"/>
                    <Button Content="Выход"
                            Background="#388E3C" Foreground="White"
                            BorderThickness="0" Padding="15,5"
                            FontSize="13" Cursor="Hand"
                            Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основное содержимое -->
        <TabControl Grid.Row="1" Margin="15"
                    FontSize="14"
                    x:Name="MainTabControl">

            <!-- Вкладка: Общие данные -->
            <TabItem Header="  Общие данные  ">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Сводка по финансам"
                                   FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,15" Foreground="#333"/>

                        <UniformGrid Columns="3" Margin="0,0,0,20">
                            <Border Background="White" CornerRadius="8" Margin="5" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="Общий доход" FontSize="13" Foreground="#888"/>
                                    <TextBlock x:Name="TotalIncomeText"
                                               Text="0 ₽" FontSize="24"
                                               FontWeight="Bold" Foreground="#4CAF50"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="8" Margin="5" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="Общий расход" FontSize="13" Foreground="#888"/>
                                    <TextBlock x:Name="TotalExpenseText"
                                               Text="0 ₽" FontSize="24"
                                               FontWeight="Bold" Foreground="#F44336"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="8" Margin="5" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="Баланс" FontSize="13" Foreground="#888"/>
                                    <TextBlock x:Name="BalanceText"
                                               Text="0 ₽" FontSize="24"
                                               FontWeight="Bold" Foreground="#2196F3"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <DataGrid x:Name="RecentTransactionsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="100"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:N2} ₽}" Width="150"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Расходы -->
            <TabItem Header="  Расходы  ">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Управление расходами"
                               FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,15" Foreground="#333"/>

                    <DataGrid x:Name="ExpensesGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              GridLinesVisibility="Horizontal"
                              CanUserAddRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ExpenseID}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding ExpenseName}" Width="*"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding ExpenseAmount, StringFormat={}{0:N2} ₽}" Width="150"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding ExpenseDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Название" FontSize="12" Foreground="#888"/>
                                    <TextBox x:Name="ExpenseNameBox" Height="30" FontSize="13" Padding="5,3"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0">
                                    <TextBlock Text="Сумма" FontSize="12" Foreground="#888"/>
                                    <TextBox x:Name="ExpenseAmountBox" Height="30" FontSize="13" Padding="5,3"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="Дата" FontSize="12" Foreground="#888"/>
                                    <DatePicker x:Name="ExpenseDatePicker" Height="30" FontSize="13"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Добавить"
                                    Background="#4CAF50" Foreground="White"
                                    BorderThickness="0" Padding="20,8"
                                    FontSize="13" Cursor="Hand" Margin="5,0"
                                    Click="AddExpense_Click"/>
                            <Button Content="Удалить"
                                    Background="#F44336" Foreground="White"
                                    BorderThickness="0" Padding="20,8"
                                    FontSize="13" Cursor="Hand" Margin="5,0"
                                    Click="DeleteExpense_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка: Доходы -->
            <TabItem Header="  Доходы  ">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Управление доходами"
                               FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,15" Foreground="#333"/>

                    <DataGrid x:Name="IncomesGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              GridLinesVisibility="Horizontal"
                              CanUserAddRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding IncomeID}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding IncomeName}" Width="*"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding IncomeAmount, StringFormat={}{0:N2} ₽}" Width="150"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding IncomeDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Название" FontSize="12" Foreground="#888"/>
                                    <TextBox x:Name="IncomeNameBox" Height="30" FontSize="13" Padding="5,3"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0">
                                    <TextBlock Text="Сумма" FontSize="12" Foreground="#888"/>
                                    <TextBox x:Name="IncomeAmountBox" Height="30" FontSize="13" Padding="5,3"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="Дата" FontSize="12" Foreground="#888"/>
                                    <DatePicker x:Name="IncomeDatePicker" Height="30" FontSize="13"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Добавить"
                                    Background="#4CAF50" Foreground="White"
                                    BorderThickness="0" Padding="20,8"
                                    FontSize="13" Cursor="Hand" Margin="5,0"
                                    Click="AddIncome_Click"/>
                            <Button Content="Удалить"
                                    Background="#F44336" Foreground="White"
                                    BorderThickness="0" Padding="20,8"
                                    FontSize="13" Cursor="Hand" Margin="5,0"
                                    Click="DeleteIncome_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка: Финансовые цели -->
            <TabItem Header="  Финансовые цели  ">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Финансовые цели"
                               FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,15" Foreground="#333"/>

                    <ItemsControl x:Name="TargetsItemsControl" Grid.Row="1">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8"
                                        Margin="5" Padding="15" Width="250">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TargetName}"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="#333" Margin="0,0,0,5"/>
                                        <TextBlock Foreground="#888" FontSize="12" Margin="0,0,0,8">
                                            <Run Text="Цель: "/>
                                            <Run Text="{Binding TargetAmount, StringFormat={}{0:N2} ₽}"/>
                                        </TextBlock>
                                        <ProgressBar Value="{Binding Progress}"
                                                     Maximum="100" Height="20"
                                                     Foreground="#4CAF50"
                                                     Background="#E0E0E0"/>
                                        <TextBlock Foreground="#4CAF50" FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,5,0,0">
                                            <Run Text="{Binding Progress, StringFormat={}{0:N0}}"/>
                                            <Run Text="%"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#888" FontSize="11" Margin="0,5,0,0">
                                            <Run Text="Срок: "/>
                                            <Run Text="{Binding EndDate, StringFormat=dd.MM.yyyy}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Название цели" FontSize="12" Foreground="#888"/>
                                    <TextBox x:Name="TargetNameBox" Height="30" FontSize="13" Padding="5,3"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0">
                                    <TextBlock Text="Сумма цели" FontSize="12" Foreground="#888"/>
                                    <TextBox x:Name="TargetAmountBox" Height="30" FontSize="13" Padding="5,3"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="Дата завершения" FontSize="12" Foreground="#888"/>
                                    <DatePicker x:Name="TargetEndDatePicker" Height="30" FontSize="13"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Добавить цель"
                                    Background="#4CAF50" Foreground="White"
                                    BorderThickness="0" Padding="20,8"
                                    FontSize="13" Cursor="Hand" Margin="5,0"
                                    Click="AddTarget_Click"/>
                            <Button Content="Удалить цель"
                                    Background="#F44336" Foreground="White"
                                    BorderThickness="0" Padding="20,8"
                                    FontSize="13" Cursor="Hand" Margin="5,0"
                                    Click="DeleteTarget_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка: Экспорт -->
            <TabItem Header="  Экспорт  ">
                <Grid Margin="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Экспорт данных"
                                   FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,30" Foreground="#333"/>

                        <Button Content="Экспорт в Word"
                                Width="250" Height="50"
                                FontSize="16"
                                Background="#2196F3" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="ExportWord_Click"
                                Margin="0,0,0,15"/>

                        <TextBlock x:Name="ExportStatusText"
                                   Text="" FontSize="13"
                                   HorizontalAlignment="Center"
                                   Foreground="#4CAF50"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
